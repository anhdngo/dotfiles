{{- $gamedev := eq (default "gamedev" (get . "profile")) "gamedev" -}}
# Environment Variables
export EDITOR=nvim
export WS=$HOME/Workspace
export AS=$HOME/Assets
export CONFIG=$HOME/.config
{{- if $gamedev }}
export GWS=$HOME/GodotProjects
{{- end }}
{{- if and (not .headless) $gamedev }}

# Godot — installed/updated by `godot-update`; these symlink paths stay
# stable across versions
export GODOT_PATH="$HOME/.local/lib/godot/godot"
export GODOT_NET_PATH="$HOME/.local/lib/godot/godotnet"
{{- end }}

mkdir -p "$WS" "$AS"{{ if $gamedev }} "$GWS"{{ end }}

# Ease of Use
alias sl="ls"
alias l="ls"
alias ll="ls -lahF"
alias rl="exec $SHELL"
alias :q=exit
alias c=clear
alias vo=nvim
alias vi=nvim
alias vim=nvim
alias g=git
alias dk=docker
alias ack=ag
alias pthon=python
alias py=python
alias neofetch="fastfetch"
{{- if .steamdeck }}
alias nvim="flatpak run io.neovim.nvim"
{{- end }}
{{- if .gui }}
alias e="nautilus . & disown"
alias f="nautilus . & disown"
{{- end }}

alias encrypt="7z a -p -mx=9 -mhe -t7z"
alias serve="python -m http.server"

# chezmoi (GNOME settings are saved with the czsave-dconf command in ~/.local/bin)
alias cz=chezmoi
alias czd="chezmoi cd"

# Bitwarden: unlock the vault for this shell (needed before chezmoi can
# render bitwarden-backed templates or install-age-key can run)
alias bwu='export BW_SESSION=$(bw unlock --raw)'

# Directory Shortcuts
alias dt='cd ~/Desktop'
alias dl='cd ~/Downloads'
alias doc='cd ~/Documents'
alias cf='cd $CONFIG'
alias ws='cd $WS'
alias as='cd $AS'
{{- if $gamedev }}
alias gws='cd $GWS'
{{- end }}
{{- if .wsl }}
alias wh='cd ~/winhome'
{{- end }}
{{- if .gui }}

alias pc='cd ~/pCloudDrive'
alias fln='cd ~/Filen'
alias cm='cd ~/.local/share/Cryptomator/mnt/'
alias vaults='cd ~/.local/share/Cryptomator/mnt/'

alias steam='cd ~/.var/app/com.valvesoftware.Steam/.local/share/Steam/steamapps/common'
{{- if $gamedev }}
alias gdata='cd ~/.local/share/godot/app_userdata'
{{- end }}
{{- end }}
