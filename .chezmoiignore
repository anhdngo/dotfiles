# Repo files that are never applied to the home directory
README.md
docs
dconf
firefox-policies.json

{{/* On machines whose config predates profiles, .profile is unset until the
     next `chezmoi init` — default to gamedev so the update timer keeps working */}}
{{- $profile := default "gamedev" (get . "profile") }}

{{ if eq .chezmoi.os "windows" }}
# Linux-only files (shared dotfiles like .vimrc, .gitconfig and .config/git
# still apply on Windows; .config/godot too — %APPDATA%\Godot is a symlink
# into it, so both OSes share one copy of the editor settings)
.chezmoiscripts/linux/**
.bash_profile
.bashrc
.zprofile
.zshrc
.aliases
.config/nvim
.config/systemd
.local
{{ else }}
# Windows-only files
.chezmoiscripts/windows/**
AppData
{{ end }}

{{ if not .gui }}
# Desktop/GNOME-only files
.config/input-remapper-2
.config/gtk-3.0
.local/share/applications
.local/share/icons
.local/bin/czsave-dconf
{{ end }}

{{ if or .headless (ne $profile "gamedev") }}
# Godot only on gamedev-profile desktop machines
.config/godot
.local/bin/godot-update
AppData/Roaming/Godot
AppData/Local/Programs/Godot
{{ end }}
