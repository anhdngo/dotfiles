# zsh is the login shell everywhere except the Steam Deck (see dot_zshrc),
# but bash is still what a fresh install starts in, so this stays functional.
# The Deck keeps the full bash + oh-my-bash setup.

# Enable the subsequent settings only in interactive sessions
case $- in
  *i*) ;;
    *) return;;
esac

# Make sure ~/.local/bin is on PATH even in non-login shells
if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
  PATH="$HOME/.local/bin:$PATH"
fi

{{- if .steamdeck }}
# Path to your oh-my-bash installation.
export OSH="$HOME/.oh-my-bash"

# Set name of the theme to load.
OSH_THEME="agnoster"

# To disable the uses of "sudo" by oh-my-bash, set "false" to this variable.
OMB_USE_SUDO=true

# Which completions would you like to load? (completions can be found in ~/.oh-my-bash/completions/*)
completions=(
  git
  composer
  ssh
)

# Which aliases would you like to load? (aliases can be found in ~/.oh-my-bash/aliases/*)
aliases=(
  general
)

# Which plugins would you like to load? (plugins can be found in ~/.oh-my-bash/plugins/*)
plugins=(
  git
  bashmarks
)

if [ -d "$OSH" ]; then
  source "$OSH"/oh-my-bash.sh
fi
{{- end }}

# Personal aliases and environment variables
source ~/.aliases

# If there are multiple matches for completion, Tab should cycle through them
bind 'TAB:menu-complete'

# Display a list of the matching files
bind "set show-all-if-ambiguous on"

# Perform partial (common) completion on the first Tab press, only start
# cycling full results on the second Tab press (from bash version 5)
bind "set menu-complete-display-prefix on"

# Cycle through history based on characters already typed on the line (ssh<Up>)
bind '"\e[A":history-search-backward'
bind '"\e[B":history-search-forward'

# Keep Ctrl-Left and Ctrl-Right working when the above are used
bind '"\e[1;5C":forward-word'
bind '"\e[1;5D":backward-word'

# Greet the session with the snail. Interactive-only comes free here: this file
# returns early for non-interactive shells. Guarded on cowsay existing because
# the Steam Deck (the one machine still on bash) installs no dnf/apt packages.
if command -v cowsay >/dev/null; then
    cowsay -f "$HOME/.local/share/cows/snail.cow" "mornin dink"
fi
