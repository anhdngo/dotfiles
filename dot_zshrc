# Make sure ~/.local/bin is on PATH even in non-login shells
if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
  PATH="$HOME/.local/bin:$PATH"
fi

# Launch straight into tmux, one fresh session per terminal (so two ddterm tabs
# are two independent sessions, not two views of the same one). `exec` hands the
# terminal to tmux, so quitting tmux closes the terminal like a normal shell exit.
# This sits above oh-my-zsh on purpose: tmux starts its own zsh, which reads this
# file again with $TMUX set and falls through, so oh-my-zsh only loads once.
# Guards, in order: interactive shells only (not scripts, `zsh -c`, or the shells
# Claude Code spawns); not already inside tmux; not a terminal embedded in an
# editor that drives its own UI; not a bare TTY or dumb terminal (no powerline
# glyphs there); and only where tmux actually exists (the Steam Deck has none).
if [[ -o interactive ]] && [[ -z "$TMUX" ]] \
    && [[ -z "$VSCODE_INJECTION" && -z "$INSIDE_EMACS" && -z "$NVIM" \
          && "$TERMINAL_EMULATOR" != "JetBrains-JediTerm" ]] \
    && [[ "$TERM" != "dumb" && "$TERM" != "linux" ]] \
    && command -v tmux >/dev/null; then
    exec tmux new-session
fi

# Path to your oh-my-zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# Set name of the theme to load.
ZSH_THEME="agnoster"

# Which plugins would you like to load? (plugins can be found in ~/.oh-my-zsh/plugins/*)
plugins=(
  git
)

# Prompt, matched to the tmux status bar (~/.tmux.conf.local): agnoster's
# user@host segment is black by default, which GNOME's palette renders purple -
# give it the same grey the bar's pills use. These have to be set before the theme
# loads, because it fills them in with `: ${VAR:=black}`.
AGNOSTER_CONTEXT_BG='#303030'
AGNOSTER_CONTEXT_FG='#e4e4e4'

if [ -d "$ZSH" ]; then
  source "$ZSH"/oh-my-zsh.sh
fi

# The rest of the look, which agnoster exposes no variables for: segments abut
# flat instead of being joined by a chevron, and the prompt ends in the same round
# cap the bar's pills do (U+E0B4, not agnoster's U+E0B0). This is agnoster's own
# prompt_end with the glyph swapped; %b drops bold first, so a terminal that
# brightens bold text can't draw the cap a lighter shade than the segment it caps.
SEGMENT_SEPARATOR=''
prompt_end() {
  if [[ -n $CURRENT_BG ]]; then
    echo -n " %{%b%k%F{$CURRENT_BG}%}"$'\ue0b4'
  else
    echo -n "%{%k%}"
  fi
  echo -n "%{%f%}"
  CURRENT_BG=''
}

# Personal aliases and environment variables
source ~/.aliases

# No custom keybindings: oh-my-zsh already ships the ones .bashrc had to set
# by hand (prefix history search on Up/Down, Ctrl-arrow word movement)

# Greet the session with the snail. This has to sit below the tmux block above,
# not with it: `exec tmux` replaces this shell and clears the screen, so a
# greeting printed up there would never be seen. Tmux's own zsh re-reads this
# file with $TMUX set, falls through that block, and prints the snail here.
# Guarded on cowsay existing because the Steam Deck installs no dnf/apt packages.
#if [[ -o interactive ]] && command -v cowsay >/dev/null; then
#  cowsay -f "$HOME/.local/share/cows/snail.cow" "mornin dink"
#fi

# SDKMAN, on machines that have it (its installer insists this stays at the
# end of the file)
export SDKMAN_DIR="$HOME/.sdkman"
if [[ -s "$SDKMAN_DIR/bin/sdkman-init.sh" ]]; then
  source "$SDKMAN_DIR/bin/sdkman-init.sh"
fi

# Leave a clean exit status behind: agnoster prints a ✘ segment when the last
# command failed, and a skipped SDKMAN would otherwise mark every fresh prompt.
true
