# ~/.zprofile: read by zsh login shells (before ~/.zshrc).
# Mirrors ~/.bash_profile so the environment is the same whichever shell a
# session lands in.

# PATH
if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
    PATH="$HOME/.local/bin:$PATH"
fi
if [ -d "$HOME/.local/share/JetBrains/Toolbox/scripts" ]; then
    PATH="$PATH:$HOME/.local/share/JetBrains/Toolbox/scripts"
fi
export PATH

export EDITOR=nvim
