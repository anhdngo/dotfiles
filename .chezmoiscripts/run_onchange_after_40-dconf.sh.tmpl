{{ if .gui -}}
#!/bin/bash
# Loads GNOME settings. Re-runs whenever dconf.ini changes.
# Resave current settings with the `czsave-dconf` alias.
# dconf.ini hash: {{ include "dconf.ini" | sha256sum }}
set -eu

echo "==> Loading GNOME settings from dconf.ini"
# -f: skip non-writable (policy-locked) keys instead of aborting — a full
# `dconf dump /` always contains a few of them
dconf load -f / < "{{ .chezmoi.sourceDir }}/dconf.ini"
{{ end -}}
