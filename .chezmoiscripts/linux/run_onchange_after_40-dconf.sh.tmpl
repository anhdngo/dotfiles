{{ if .gui -}}
#!/bin/bash
# Loads GNOME settings from the scoped dumps in dconf/. Re-runs whenever any
# of them change. Resave current settings with `czsave-dconf`.
#
# File hashes (trigger re-run on change):
{{ range $name, $path := .dconf -}}
# {{ $name }}: {{ include (printf "dconf/%s.ini" $name) | sha256sum }}
{{ end -}}
set -eu

echo "==> Loading GNOME settings"
{{ range $name, $path := .dconf -}}
# -f: skip non-writable (policy-locked) keys instead of aborting
dconf load -f {{ $path }} < "{{ $.chezmoi.sourceDir }}/dconf/{{ $name }}.ini"
{{ end -}}
{{ end -}}
